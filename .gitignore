# .gitignore for Engine Design Repository
# Ignore everything by default
*

# Allow git to traverse directories
!*/

# But include pintle engine files
!pintle_models/
!pintle_pipeline/
!examples/pintle_engine/

# Include parachute dynamics files
!parachute/
!examples/parachute/
!README_PARACHUTE.md
!BUGFIXES_SUMMARY.md
!INFLATION_ISSUE_SUMMARY.md

# Within pintle directories, ignore cache and compiled files
pintle_models/**/__pycache__/
pintle_models/**/*.pyc
pintle_pipeline/**/__pycache__/
pintle_pipeline/**/*.pyc
examples/pintle_engine/**/__pycache__/
examples/pintle_engine/**/*.pyc
**/*.npz
**/*.png
**/*.jpg
**/*.pdf

# But include important pintle source files
!pintle_models/*.py
!pintle_pipeline/*.py
!pintle_pipeline/*.md
!examples/pintle_engine/*.py
!examples/pintle_engine/*.yaml
!examples/pintle_engine/*.md
!examples/pintle_engine/*.tex

# Include parachute source files
!parachute/*.py
!examples/parachute/*.yaml

# Include README in root
!README.md
!README_PARACHUTE.md

# Include guide files
!SETUP_REPOS.md
!REPO_SEPARATION_GUIDE.md
!.gitignore.engine
!.gitignore.parachute

# Include .gitignore itself
!.gitignore

# Include requirements
!requirements.txt

